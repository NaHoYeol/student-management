generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  STUDENT
  PARENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)

  school    String?
  grade     String?
  classDay  String?
  classTime String?

  // 강사 프로필
  subject     String?
  academyName String?
  isApproved  Boolean   @default(false)
  approvedAt  DateTime?

  instructorId String?
  instructor   User?  @relation("InstructorStudents", fields: [instructorId], references: [id])
  students     User[] @relation("InstructorStudents")

  accounts    Account[]
  sessions    Session[]
  assignments Assignment[] @relation("CreatedAssignments")
  submissions Submission[]
  analysisResults StudentAnalysisResult[]
  parentLinks     ParentLink[] @relation("ParentLinks")
  linkedParents   ParentLink[] @relation("LinkedParents")
  settings        Setting[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Assignment {
  id             String  @id @default(cuid())
  title          String
  description    String?
  totalQuestions Int
  isActive          Boolean @default(true)
  analysisPublished Boolean @default(false)
  examContent       String? @db.Text
  dueDate           DateTime?
  category          String  @default("PRIVATE") // "OFFICIAL" (평가원/교육청) | "PRIVATE" (사설)
  examDate          DateTime? // 평가원/교육청 모의고사 시행일

  targetType       String  @default("ALL")
  targetClasses    String? @db.Text
  targetStudentIds String? @db.Text

  lastRealSubmissionAt DateTime? // 마지막 실제 학생 제출 시각 (캐시 디바운스용)

  createdById String
  createdBy   User   @relation("CreatedAssignments", fields: [createdById], references: [id])

  questions   Question[]
  submissions Submission[]
  analysisResults StudentAnalysisResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id             String @id @default(cuid())
  assignmentId   String
  questionNumber Int
  correctAnswer  String
  questionType   String @default("choice") // "choice" | "multiple" | "subjective"
  points         Int    @default(1)

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, questionNumber])
}

model Submission {
  id           String    @id @default(cuid())
  studentId    String
  assignmentId String
  score        Int?
  totalPoints  Int?
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?
  isAgent      Boolean   @default(false)
  agentGrade   Int?
  resubmitApproved Boolean @default(false)

  student    User               @relation(fields: [studentId], references: [id])
  assignment Assignment         @relation(fields: [assignmentId], references: [id])
  answers    SubmissionAnswer[]

  @@unique([studentId, assignmentId])
}

model ClassOption {
  id    String @id @default(cuid())
  type  String // "school" | "grade" | "classDay" | "classTime"
  value String

  @@unique([type, value])
}

model Setting {
  id     String  @id @default(cuid())
  key    String
  value  String
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
}

model SubmissionAnswer {
  id             String  @id @default(cuid())
  submissionId   String
  questionNumber Int
  studentAnswer  String
  isCorrect      Boolean @default(false)

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionNumber])
}

model StudentAnalysisResult {
  id             String   @id @default(cuid())
  studentId      String
  assignmentId   String
  score          Int
  totalPoints    Int
  correctRate    Int
  grade          Int
  rank           Int
  totalStudents  Int
  percentile     Float
  weakPattern    String?
  feedback       String?  @db.Text
  questionBreakdown String? @db.Text
  wrongQuestions    String? @db.Text

  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, assignmentId])
}

model MonthlyReport {
  id          String   @id @default(cuid())
  month       String   @unique // "2025-03"
  status      String   @default("PENDING") // PENDING, ANALYZED, PUBLISHED
  analyzedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students MonthlyReportStudent[]
}

model MonthlyReportStudent {
  id              String @id @default(cuid())
  monthlyReportId String
  studentId       String
  studentName     String?
  analysisData    Json
  createdAt       DateTime @default(now())

  monthlyReport MonthlyReport @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)

  @@unique([monthlyReportId, studentId])
}

model ParentLink {
  id        String   @id @default(cuid())
  parentId  String
  studentId String?
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED

  // 학부모가 직접 입력한 정보 (신청 시)
  studentName String?
  schoolName  String?
  gradeName   String?

  parent  User  @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  student User? @relation("LinkedParents", fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
