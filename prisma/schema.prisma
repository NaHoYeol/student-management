generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STUDENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)

  school    String?
  grade     String?
  classDay  String?
  classTime String?

  instructorId String?
  instructor   User?  @relation("InstructorStudents", fields: [instructorId], references: [id])
  students     User[] @relation("InstructorStudents")

  accounts    Account[]
  sessions    Session[]
  assignments Assignment[] @relation("CreatedAssignments")
  submissions Submission[]
  analysisResults StudentAnalysisResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Assignment {
  id             String  @id @default(cuid())
  title          String
  description    String?
  totalQuestions Int
  isActive          Boolean @default(true)
  analysisPublished Boolean @default(false)
  examContent       String? @db.Text

  targetType       String  @default("ALL")
  targetClasses    String? @db.Text
  targetStudentIds String? @db.Text

  createdById String
  createdBy   User   @relation("CreatedAssignments", fields: [createdById], references: [id])

  questions   Question[]
  submissions Submission[]
  analysisResults StudentAnalysisResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Question {
  id             String @id @default(cuid())
  assignmentId   String
  questionNumber Int
  correctAnswer  String
  questionType   String @default("choice") // "choice" | "multiple" | "subjective"
  points         Int    @default(1)

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, questionNumber])
}

model Submission {
  id           String    @id @default(cuid())
  studentId    String
  assignmentId String
  score        Int?
  totalPoints  Int?
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?
  isAgent      Boolean   @default(false)
  agentGrade   Int?
  resubmitApproved Boolean @default(false)

  student    User               @relation(fields: [studentId], references: [id])
  assignment Assignment         @relation(fields: [assignmentId], references: [id])
  answers    SubmissionAnswer[]

  @@unique([studentId, assignmentId])
}

model ClassOption {
  id    String @id @default(cuid())
  type  String // "school" | "grade" | "classDay" | "classTime"
  value String

  @@unique([type, value])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SubmissionAnswer {
  id             String  @id @default(cuid())
  submissionId   String
  questionNumber Int
  studentAnswer  String
  isCorrect      Boolean @default(false)

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionNumber])
}

model StudentAnalysisResult {
  id             String   @id @default(cuid())
  studentId      String
  assignmentId   String
  score          Int
  totalPoints    Int
  correctRate    Int
  grade          Int
  rank           Int
  totalStudents  Int
  percentile     Float
  weakPattern    String?
  feedback       String?  @db.Text
  questionBreakdown String? @db.Text
  wrongQuestions    String? @db.Text

  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, assignmentId])
}
